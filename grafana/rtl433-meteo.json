{
  "uid": "rtl433-meteo",
  "title": "rtl433-meteo \u00b7 Weather Stations",
  "tags": [
    "weather",
    "rtl_433",
    "victoriametrics"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_VM",
        "type": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "DS_SUNMOON",
        "type": "datasource",
        "label": "Sun & Moon source",
        "query": "fetzerch-sunandmoon-datasource",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "model",
        "type": "query",
        "label": "Model",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_VM}"
        },
        "query": {
          "query": "label_values(meteo_info, model)",
          "refId": "var"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1,
        "hide": 0
      },
      {
        "name": "id",
        "type": "query",
        "label": "Device ID",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_VM}"
        },
        "query": {
          "query": "label_values(meteo_info, id)",
          "refId": "var"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "type": "dashboard",
        "hide": true,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "name": "Annotations & Alerts",
        "enable": true
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "\u2600\ufe0f  Current Conditions",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
