    {
      "type": "gauge",
      "id": 2,
      "title": "Temperature",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VM}"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_VM}"
          },
          "editorMode": "code",
          "expr": "meteo_temperature_celsius{model=~\"$model\", id=~\"$id\"}",
          "legendFormat": "{{model}} \u00b7 {{id}}",
          "instant": false,
          "range": true,
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": -30,
          "max": 50,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": -30
              },
              {
                "color": "light-blue",
                "value": 0
              },
              {
                "color": "green",
                "value": 10
              },
              {
                "color": "orange",
                "value": 24
              },
              {
                "color": "red",
                "value": 32
              }
            ]
          }
        },
        "overrides": []
      }
    },
